# =============================================================================
# UnityProject/.gitignore
# 基于 Unity 官方模板 + TEngine / HybridCLR / YooAsset 构建产物
# 参考: https://github.com/github/gitignore/blob/main/Unity.gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Unity 引擎缓存与临时文件
# -----------------------------------------------------------------------------
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Ll]ogs/
/[Mm]emoryCaptures/
sysinfo.txt

# -----------------------------------------------------------------------------
# Player / AssetBundle 构建产物
# -----------------------------------------------------------------------------
/[Bb]uild/
/[Bb]uilds/
/[Bb]undles/
/[Bb]in/
*.apk
*.aab
*.unitypackage

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
ExportedObj/
.consulo/

# Unity 生成的调试符号 meta
*.pidb.meta
*.pdb.meta
*.mdb.meta

# -----------------------------------------------------------------------------
# HybridCLR 生成与编译产物
# -----------------------------------------------------------------------------
/[Hh]ybridCLRData/
/[Aa]ssets/HybridCLRGenerate/
/[Aa]ssets/HybridCLRGenerate.meta

# 热更 DLL 复制到 AssetRaw 的 .bytes（由 HybridCLR Build 生成，勿提交）
/[Aa]ssets/AssetRaw/DLL/*.bytes
/[Aa]ssets/AssetRaw/DLL/*.bytes.meta

# -----------------------------------------------------------------------------
# YooAsset 内置资源与打包缓存（打 AB 时自动生成）
# -----------------------------------------------------------------------------
/[Aa]ssets/StreamingAssets/
/[Aa]ssets/StreamingAssets.meta
/[Aa]ssets/TEngine/AssetSetting/Resources/BuiltinFileManifest.asset
/[Aa]ssets/TEngine/AssetSetting/Resources/BuiltinFileManifest.asset.meta
package/
yoo/

# -----------------------------------------------------------------------------
# 其他本地/临时资源目录
# -----------------------------------------------------------------------------
/[Aa]ssets/AATemp/
/[Aa]ssets/AATemp.meta
/[Aa]ssets/TextMesh Pro/
/[Aa]ssets/TextMesh Pro.meta
/[Ss]andbox/

# -----------------------------------------------------------------------------
# 用户本地 Editor 设置（EditorUserSettings.asset 可提交）
# -----------------------------------------------------------------------------
/[Uu]serSettings/Layouts/
/[Uu]serSettings/Search.settings
/[Uu]serSettings/Search.index

# -----------------------------------------------------------------------------
# 系统文件
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# JetBrains Rider 插件（自动生成）
# -----------------------------------------------------------------------------
/[Aa]ssets/Plugins/Editor/JetBrains*

# Gradle（Android 导出时可能生成）
.gradle/
crashlytics-build.properties
